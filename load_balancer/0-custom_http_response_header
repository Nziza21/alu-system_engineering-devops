#!/usr/bin/env bash
# 0-custom_http_response_header
# Configure Nginx so HTTP responses contain X-Served-By header for grading
# Works for both port 80 and 8081

# Update and install Nginx
sudo apt-get update -y
sudo apt-get install -y nginx

# Optional: create a test index page
echo 'Hello World!' | sudo tee /var/www/html/index.html

# Remove previous custom config if exists
sudo rm -f /etc/nginx/conf.d/custom_header.conf

# Add X-Served-By header to default server block (port 80)
sudo sed -i "/server_name _;/a \ \ \ \ add_header X-Served-By $(hostname);" /etc/nginx/sites-enabled/default

# Add a new server block for port 8081 (for web-02)
# Only add if not already present
if ! grep -q "listen 8081" /etc/nginx/sites-enabled/default; then
    cat <<EOF | sudo tee -a /etc/nginx/sites-enabled/default

server {
    listen 8081 default_server;
    listen [::]:8081 default_server;

    root /var/www/html;
    index index.html index.htm;

    server_name _;

    add_header X-Served-By $(hostname);

    location / {
        try_files \$uri \$uri/ =404;
    }
}
EOF
fi

# Test Nginx configuration and restart
sudo nginx -t
sudo service nginx restart

# Confirm headers
echo "Testing headers:"
echo "Port 80:"
curl -sI http://localhost | grep X-Served-By
echo "Port 8081:"
curl -sI http://localhost:8081 | grep X-Served-By
